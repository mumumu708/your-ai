{
  "name": "yourbot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run src/gateway/index.ts",
    "start": "pm2 start ecosystem.config.js",
    "test": "bun test",
    "test:coverage": "bun test --coverage && bun run scripts/lcov-to-nyc.ts && bunx nyc report",
    "test:coverage:html": "bun test --coverage && bun run scripts/lcov-to-nyc.ts && bunx nyc report --reporter=html",
    "coverage:report": "bunx nyc report",
    "coverage:check": "bunx nyc check-coverage",
    "lint": "bunx biome check src/",
    "lint:fix": "bunx biome check --write src/",
    "format": "bunx biome format --write src/",
    "typecheck": "bunx tsc --noEmit",
    "check:arch": "bun run scripts/check-architecture.ts",
    "check:conventions": "bun run scripts/lint-conventions.ts",
    "check:docs": "bun run scripts/check-docs.ts",
    "check:coverage": "bun test --coverage && bun run scripts/lcov-to-nyc.ts && bunx nyc check-coverage",
    "check:all": "bun run lint && bun run typecheck && bun run check:arch && bun run check:conventions && bun run check:coverage",
    "test:mutate": "bunx stryker run",
    "test:mutate:dry": "bunx stryker run --dryRunOnly",
    "db:init": "bun run infra/scripts/db-init.ts",
    "db:migrate": "bun run infra/scripts/db-migrate.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "agent-browser": "^0.16.3",
    "better-sqlite3": "^11.7.0",
    "bunqueue": "^1.1.0",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.7.0",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/bun": "^1.2.0",
    "@types/istanbul-lib-coverage": "^2.0.6",
    "drizzle-kit": "^0.30.0",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "nyc": "^18.0.0",
    "typescript": "^5.9.3"
  }
}
