{
  "extends": "@istanbuljs/nyc-config-typescript",
  "all": true,
  "include": ["src/**/*.ts"],
  "exclude": [
    "**/*.test.ts",
    "**/*.integration.test.ts",
    "**/*.e2e.test.ts",
    "**/test-utils/**",
    "**/__fixtures__/**",
    "**/*.types.ts",
    "**/*.d.ts"
  ],
  "reporter": ["text", "text-summary", "lcov", "html"],
  "report-dir": "coverage",
  "temp-dir": ".nyc_output",
  "check-coverage": true,
  "per-file": true,
  "lines": 100,
  "functions": 100,
  "branches": 90,
  "statements": 100,
  "skip-full": false
}
