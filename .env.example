# YourBot Configuration
NODE_ENV=development
PORT=3000
WS_PORT=3001

# 启用的通道 (逗号分隔: feishu,telegram,web)
ENABLED_CHANNELS=feishu

# ── 复杂任务 Agent 配置 ──────────────────────────────────
# 主 agent: claude / codex / opencode (默认: claude)
# COMPLEX_AGENT_PRIMARY=claude
# 兜底 agent: 主 agent 不可用时自动切换 (默认: 主 agent 之外的另一个)
# COMPLEX_AGENT_FALLBACK=codex

# ── Claude Code ──────────────────────────────────────────
# claude CLI 路径，默认使用 PATH 中的 claude
# CLAUDE_PATH=claude
# 默认模型：sonnet / haiku / opus
# CLAUDE_MODEL=sonnet

# ── OpenCode (可选) ──────────────────────────────────────
# opencode CLI 路径，默认使用 PATH 中的 opencode
# OPENCODE_PATH=opencode

# ── LightLLM (简单任务) ─────────────────────────────────
# OpenAI 兼容 API 配置
LIGHT_LLM_API_KEY=your-api-key-here
LIGHT_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LIGHT_LLM_MODEL=glm-4.5-air

# 其他可选 Base URL:
# DeepSeek:  https://api.deepseek.com/v1
# Qwen:     https://dashscope.aliyuncs.com/compatible-mode/v1
# OpenAI:   https://api.openai.com/v1

# ── 飞书 (可选) ─────────────────────────────────────────
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=

# ── Telegram (可选) ──────────────────────────────────────
# TELEGRAM_BOT_TOKEN=

# ── 认证 (生产环境必须) ──────────────────────────────────
# JWT 密钥 (用于 Web 通道 WebSocket 认证, HMAC-SHA256)
# JWT_SECRET=
# API 密钥白名单 (逗号分隔)
# API_KEYS=key1,key2,key3
# 飞书事件验证 Token (可选)
# FEISHU_VERIFICATION_TOKEN=
# Telegram Webhook 密钥 (可选, 使用 Webhook 模式时)
# TELEGRAM_WEBHOOK_SECRET=

# ── 加密 (生产环境必须) ──────────────────────────────────
# 64位十六进制字符 = 32字节主密钥
# 可用 node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" 生成
# YOURBOT_MASTER_KEY=

# ── OpenViking ─────────────────────────────────────────
OPENVIKING_URL=http://localhost:1933
# VOLCENGINE_API_KEY=your-volcengine-api-key

# ── 数据库 ──────────────────────────────────────────────
DB_PATH=./data/yourbot.db

# ── Harness Engineering ──────────────────────────────────
# 用户空间根目录 (默认: ~/.your-ai/user-space)
# 开发环境可留空使用默认值；生产环境建议设置独立路径
# USER_SPACE_ROOT=~/.your-ai/user-space
# USER_SPACE_ROOT=/data/your-ai-users
# 管理员用户 ID (逗号分隔)
# ADMIN_USER_IDS=feishu:xxx,telegram:yyy

# ── 日志 ────────────────────────────────────────────────
LOG_LEVEL=info
